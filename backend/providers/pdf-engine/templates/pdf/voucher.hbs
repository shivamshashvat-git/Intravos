<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>:root { --primary-color: {{branding.primary_color}}; --secondary-color: {{branding.secondary_color}}; }</style>
  <style>{{{baseCSS}}}</style>
</head>
<body>

  <!-- HEADER -->
  <div class="pdf-header">
    <div class="pdf-header-logo">
      {{#if branding.logo_url}}<img src="{{branding.logo_url}}" alt="{{branding.agency_name}}">{{/if}}
      <div>
        <div class="pdf-header-agency-name">{{branding.agency_name}}</div>
      </div>
    </div>
    <div class="pdf-header-agency-details">
      {{#if branding.agency_address}}<div>{{branding.agency_address}}</div>{{/if}}
      {{#if branding.agency_phone}}<div>📞 {{branding.agency_phone}}</div>{{/if}}
      {{#if branding.agency_email}}<div>✉ {{branding.agency_email}}</div>{{/if}}
    </div>
  </div>

  <!-- TITLE BLOCK -->
  <div class="pdf-title-block">
    <div>
      <div class="pdf-title">Supplier Voucher</div>
      <div class="pdf-subtitle">Booking Ref: {{booking_ref}}</div>
    </div>
    <div style="text-align: right;">
      <div style="font-size: 10px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Issued To</div>
      <div style="font-size: 14px; font-weight: 700; color: var(--primary-color);">{{supplier_name}}</div>
    </div>
  </div>

  <!-- BOOKING DETAILS -->
  <div class="pdf-section">
    <div class="pdf-section-title">Booking Information</div>
    <div class="info-grid">
      <div>
        <div class="info-row"><span class="info-label">Booking Ref</span><span class="info-value">{{booking_ref}}</span></div>
        {{#if destination}}<div class="info-row"><span class="info-label">Destination</span><span class="info-value">{{destination}}</span></div>{{/if}}
        <div class="info-row"><span class="info-label">Travel Dates</span><span class="info-value">{{formatDate travel_start_date}} – {{formatDate travel_end_date}}</span></div>
      </div>
      <div>
        {{#if guest_names}}<div class="info-row"><span class="info-label">Guest Name(s)</span><span class="info-value" style="font-weight:700;">{{guest_names}}</span></div>{{/if}}
        {{#if booking_reference}}<div class="info-row"><span class="info-label">Confirmation No.</span><span class="info-value">{{booking_reference}}</span></div>{{/if}}
      </div>
    </div>
  </div>

  <!-- SERVICE DETAILS -->
  <div class="pdf-section">
    <div class="pdf-section-title">Service Details</div>
    <div class="info-grid">
      <div>
        <div class="info-row"><span class="info-label">Service Type</span><span class="info-value">{{uppercase service_type}}</span></div>
        <div class="info-row"><span class="info-label">Service</span><span class="info-value" style="font-weight:700;">{{service_title}}</span></div>
        {{#if supplier_name}}<div class="info-row"><span class="info-label">Supplier</span><span class="info-value">{{supplier_name}}</span></div>{{/if}}
      </div>
      <div>
        {{#if room_type}}<div class="info-row"><span class="info-label">Room Type</span><span class="info-value">{{room_type}}</span></div>{{/if}}
        {{#if meal_plan}}<div class="info-row"><span class="info-label">Meal Plan</span><span class="info-value">{{meal_plan}}</span></div>{{/if}}
        {{#if flight_number}}<div class="info-row"><span class="info-label">Flight</span><span class="info-value">{{flight_number}}</span></div>{{/if}}
        {{#if (or departure_time arrival_time)}}<div class="info-row"><span class="info-label">Schedule</span><span class="info-value">{{defaultVal departure_time ""}} → {{defaultVal arrival_time ""}}</span></div>{{/if}}
      </div>
    </div>
  </div>

  <!-- SPECIAL REQUESTS -->
  {{#if special_requests}}
  <div class="terms-box">
    <h4>Special Instructions / Requests</h4>
    <p>{{special_requests}}</p>
  </div>
  {{/if}}

  <!-- IMPORTANT NOTES -->
  <div class="terms-box" style="margin-top:15px; background: #fffaf0; border-color: #fbd38d; border-left-color: #dd6b20;">
    <h4 style="color: #c05621;">Important Information</h4>
    <p>• Please present a copy of this voucher at the time of check-in / service start.</p>
    <p>• All services mentioned are confirmed as per the booking reference above.</p>
    <p>• For any urgent assistance, please contact the agency details mentioned in the header.</p>
  </div>

  <!-- FOOTER -->
  <div class="pdf-footer">
    <p>This document is electronically generated and is valid without a physical signature.</p>
    <p>© {{branding.agency_name}} · Generated on {{generated_at}}</p>
  </div>

</body>
</html>
