NODE_ENV=development
PORT=4000

# Supabase (required for auth and data)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Cron jobs (POST /api/cron/*)
CRON_SECRET=change-me-in-production

# Redis (optional — graceful bypass if not set)
REDIS_URL=redis://localhost:6379

# Sentry error tracking (optional — silent if not set)
SENTRY_DSN=

# Encryption (required for token generation)
ENCRYPTION_KEY=your-32-byte-hex-key-here

# Platform manager kill-switch
PLATFORM_MANAGER_ENABLED=true

# Google Places API (required for hotel autocomplete in itineraries)
GOOGLE_PLACES_API_KEY=

# Optional: storage bucket defaults
STORAGE_BUCKET=uploads
STORAGE_BUCKET_UPLOADS=uploads
STORAGE_BUCKET_SCREENSHOTS=screenshots
STORAGE_BUCKET_ATTACHMENTS=attachments
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_OFFERS=offers
STORAGE_BUCKET_LOGOS=logos
STORAGE_BUCKET_RATE_CARDS=rate-cards
STORAGE_BUCKET_PDFS=pdfs
STORAGE_BUCKET_RECEIPTS=receipts

# Push Notifications (PWA) — generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@yourdomain.com
